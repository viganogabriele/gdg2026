# Copy this file to .env.local and fill in your keys.
# Variables MUST have the EXPO_PUBLIC_ prefix to be accessible in the client bundle.

# Primary AI provider — Google Gemini 2.0 Flash
# Get your key at: https://console.cloud.google.com → APIs → Generative Language API
EXPO_PUBLIC_GEMINI_API_KEY=

# Fallback AI provider — OpenRouter (optional)
# Get your key at: https://openrouter.ai/keys
EXPO_PUBLIC_OPEN_ROUTER_API_KEY=
