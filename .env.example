# Copy this file to .env.local and fill in your API keys.
# Variables MUST have the EXPO_PUBLIC_ prefix to be accessible in the client bundle.

# Primary AI — Google Gemini 2.0 Flash (Google Cloud Console)
# https://console.cloud.google.com → APIs & Services → Generative Language API
EXPO_PUBLIC_GEMINI_API_KEY=

# Fallback AI — OpenRouter (optional, same model via different auth)
# https://openrouter.ai/keys
EXPO_PUBLIC_OPEN_ROUTER_API_KEY=
